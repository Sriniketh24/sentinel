# Hugging Face
HF_API_TOKEN=hf_your_token_here

# SEC EDGAR
SEC_EDGAR_USER_AGENT=YourName your@email.com

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sentinel_docs

# RAG
TOP_K=10
RERANK_TOP_K=5

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sentinel

# Model config
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
GENERATION_MODEL=HuggingFaceH4/zephyr-7b-beta
NER_MODEL=dslim/bert-base-NER
CLASSIFIER_MODEL=typeform/distilbert-base-uncased-mnli

# API
API_HOST=0.0.0.0
API_PORT=8000
